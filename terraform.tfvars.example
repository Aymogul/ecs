region             = "us-east-1"
env                = "dev"
vpc_cidr           = "10.0.0.0/16"
public_subnets     = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnets    = ["10.0.11.0/24", "10.0.12.0/24"]
availability_zones = ["us-east-1a", "us-east-1b"]

image          = "nginx:latest"
container_port = 80
desired_count  = 2
min_capacity   = 2
max_capacity   = 4
